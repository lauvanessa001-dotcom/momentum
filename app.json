{
  "expo": {
    "owner": "vlau001s-team",
    "name": "Momentum",
    "slug": "momentum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "momentum",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F4EF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vanessalau.momentum",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Momentum uses notifications to remind you about your habits and daily check-ins.",
        "UIBackgroundModes": ["fetch"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.momentum.motivationapp",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3639bcbb-0a22-43f1-b1be-c1610b8e8517"
      }
    }
  }
}
